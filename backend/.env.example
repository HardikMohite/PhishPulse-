# Environment Configuration for PhishPulse Backend
# Copy this file to .env and fill in your actual values

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-super-secret-key-min-32-characters-change-this-in-production
ALGORITHM=HS256

# JWT Token Expiry Settings
ACCESS_TOKEN_EXPIRE_DAYS=1               # Default session duration (no "remember me")
REMEMBER_ME_EXPIRE_DAYS=30               # Extended session duration (with "remember me")

# API Settings
APP_NAME=PhishPulse API
DEBUG=True
API_V1_PREFIX=/api

# CORS - Frontend URLs
FRONTEND_URL=http://localhost:5173
# You can add more origins separated by commas if needed

# Database
# SQLite (default for development)
DATABASE_URL=sqlite:///./phishpulse.db

# PostgreSQL (uncomment and configure for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/phishpulse

# Email Settings
# Customize your sender email (must be verified in Brevo for production)
FROM_EMAIL=noreply@phishpulse.com

# Brevo API (for OTP and transactional emails)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here
