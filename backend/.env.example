# Environment Configuration for PhishPulse Backend
# Copy this file to .env and fill in your actual values

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-super-secret-key-min-32-characters-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Settings
APP_NAME=PhishPulse API
DEBUG=True
API_V1_PREFIX=/api

# CORS - Frontend URLs
FRONTEND_URL=http://localhost:5173
# You can add more origins separated by commas if needed

# Database
# SQLite (default for development)
DATABASE_URL=sqlite:///./phishpulse.db

# PostgreSQL (uncomment and configure for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/phishpulse

# Email Settings (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@phishpulse.com

# Twilio (for SMS/2FA - optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
